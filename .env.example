# ──────────────────────────────────────────────────────────
# CMS Core — contoh environment. Salin ke .env lalu sesuaikan.
# Jangan commit file .env asli (lihat .gitignore).
# ──────────────────────────────────────────────────────────

# App
NODE_ENV=development
PORT=3000
API_PREFIX=v1
CORS_ORIGINS=http://localhost:3000

# PostgreSQL (host service mengikuti nama service di compose)
DATABASE_URL=postgresql://cms:cms_secret@postgres:5432/cmscore?schema=public

# Redis (cache, queue, lock, rate-limit)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_ACCESS_SECRET=change-me-access-secret
JWT_ACCESS_TTL=900
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_REFRESH_TTL=1209600

# MinIO (S3-compatible object storage)
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=cms_minio
MINIO_SECRET_KEY=cms_minio_secret
MINIO_BUCKET=cms-media
MINIO_PUBLIC_URL=http://localhost:9000/cms-media

# Rate limiting (auth endpoint)
THROTTLE_TTL=60
THROTTLE_LIMIT=10

# Article locking
LOCK_TTL_SECONDS=1800

# Webhook delivery
WEBHOOK_MAX_RETRIES=5
