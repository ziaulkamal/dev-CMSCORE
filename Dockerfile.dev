# Dockerfile.dev — image development NestJS dengan hot-reload (pnpm).
# Source di-mount sebagai volume; container hanya menyiapkan toolchain & deps.
FROM node:22-alpine

# OpenSSL untuk Prisma engine; netcat untuk wait-for DB di entrypoint.
RUN apk add --no-cache openssl netcat-openbsd

# pnpm via corepack (versi mengikuti packageManager di package.json).
RUN corepack enable

WORKDIR /app

# Layer deps: manfaatkan cache selama lockfile tak berubah.
COPY package.json pnpm-lock.yaml* ./
RUN pnpm install --frozen-lockfile || pnpm install

# Prisma schema untuk generate client saat build image.
COPY prisma ./prisma
RUN pnpm prisma generate

EXPOSE 3000

# Entry men-deploy migrasi lalu start watch (lihat docker/entrypoint.dev.sh).
COPY docker/entrypoint.dev.sh /usr/local/bin/entrypoint.dev.sh
RUN chmod +x /usr/local/bin/entrypoint.dev.sh

ENTRYPOINT ["entrypoint.dev.sh"]
CMD ["pnpm", "run", "start:dev"]
