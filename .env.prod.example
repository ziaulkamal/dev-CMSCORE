# ──────────────────────────────────────────────────────────────────
# CMS Core — environment PRODUKSI. Salin ke .env.prod lalu GANTI semua
# nilai <...>. JANGAN commit .env.prod (kredensial asli).
#
#   cp .env.prod.example .env.prod
#   # lalu edit .env.prod, ganti semua placeholder <...>
#
# Cara bikin secret acak kuat:  openssl rand -base64 32
# ──────────────────────────────────────────────────────────────────

NODE_ENV=production
PORT=3000
API_PREFIX=v1

# Ganti <IP-SERVER> dengan IP publik server (mis. 123.45.67.89).
# Ini daftar origin yang boleh memanggil API dari browser (panel + domain lain).
CORS_ORIGINS=http://<IP-SERVER>,http://<IP-SERVER>:8080

# ── PostgreSQL (nilai harus sama dengan yang dipakai service postgres) ──
POSTGRES_USER=cms
POSTGRES_PASSWORD=<GANTI-password-db-kuat>
POSTGRES_DB=cmscore
DATABASE_URL=postgresql://cms:<GANTI-password-db-kuat>@postgres:5432/cmscore?schema=public

# ── Redis (WAJIB password di produksi) ──
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=<GANTI-password-redis-kuat>

# ── JWT (WAJIB ganti — pakai openssl rand -base64 32) ──
JWT_ACCESS_SECRET=<GANTI-secret-access-acak>
JWT_ACCESS_TTL=900
JWT_REFRESH_SECRET=<GANTI-secret-refresh-acak>
JWT_REFRESH_TTL=1209600

# ── MinIO (object storage) ──
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=<GANTI-access-key>
MINIO_SECRET_KEY=<GANTI-secret-key-kuat>
MINIO_BUCKET=cms-media
# URL media yang dilihat browser. Lewat proxy Nginx (path /media/), pakai IP server:
MINIO_PUBLIC_URL=http://<IP-SERVER>/media/cms-media

# ── Rate limit & lain-lain ──
THROTTLE_TTL=60
THROTTLE_LIMIT=10
LOCK_TTL_SECONDS=1800
WEBHOOK_MAX_RETRIES=5
